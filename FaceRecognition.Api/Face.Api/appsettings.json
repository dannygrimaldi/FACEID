{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft": "Warning",
            "Microsoft.AspNetCore": "Warning",
            "Face.Api": "Information",
            "Face.Api.Core.FacePipeline.Detection.ScrfdDetector": "Warning"
        }
    },

    "Qdrant": {
        "BaseUrl": "http://127.0.0.1:6333/",
        "Key": "YOUR_QDRANT_API_KEY_HERE"
    },
    "RateLimit": {
        "WindowSeconds": 60,
        "SearchMaxRequests": 3000,
        "RegisterMaxRequests": 3000,
        "TestDetectMaxRequests": 3000
    },
    "FaceRecognition": {
        "CollectionName": "faces",
        "DetectionScoreMin": 0.5,
        "MatchScoreMin": 0.8,
        "SearchTopK": 20,
        "AutoUpdateThreshold": 0.8,
        "AutoUpdateLiveWeight": 0.1,
        "TemplatesPerModality": 1
    },

    "AllowedHosts": "*",
    "ScoreMin": 0.8
}
